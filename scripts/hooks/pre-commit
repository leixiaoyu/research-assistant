#!/bin/bash
#
# Pre-commit hook - FAST checks only (~3-5 seconds)
#
# This hook runs quick linting checks to catch formatting/style issues early.
# Full test suite runs in the pre-push hook (before pushing to remote).
#
# What runs here (fast):
#   - Black formatting check
#   - Flake8 linting
#   - Mypy type checking
#
# What runs in pre-push (thorough):
#   - All of the above PLUS
#   - Full pytest with coverage
#
# To bypass (emergencies only): git commit --no-verify
#
# Installation: ./scripts/setup_hooks.sh

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Check for staged changes
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Check for Python files
STAGED_PY=$(echo "$STAGED_FILES" | grep -E '\.py$' || true)
if [ -z "$STAGED_PY" ]; then
    # No Python files staged, skip checks
    exit 0
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Pre-commit: Quick Lint Check${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Detect Python command
PYTHON_CMD="python3.14"
if ! command -v $PYTHON_CMD &> /dev/null; then
    PYTHON_CMD="python3"
fi

FAILED=0
START_TIME=$(date +%s)

# Step 1: Black (formatting)
echo -e "\n${BOLD}[1/3]${NC} Black formatting..."
if $PYTHON_CMD -m black --check --quiet src/ tests/ 2>/dev/null; then
    echo -e "      ${GREEN}✓${NC} Formatting OK"
else
    echo -e "      ${RED}✗${NC} Formatting issues found"
    echo -e "      ${YELLOW}Fix: black .${NC}"
    FAILED=1
fi

# Step 2: Flake8 (linting)
echo -e "${BOLD}[2/3]${NC} Flake8 linting..."
FLAKE8_OUTPUT=$($PYTHON_CMD -m flake8 src/ tests/ 2>&1 || true)
if [ -z "$FLAKE8_OUTPUT" ]; then
    echo -e "      ${GREEN}✓${NC} No linting issues"
else
    echo -e "      ${RED}✗${NC} Linting issues found:"
    echo "$FLAKE8_OUTPUT" | head -10
    FLAKE8_COUNT=$(echo "$FLAKE8_OUTPUT" | wc -l | tr -d ' ')
    if [ "$FLAKE8_COUNT" -gt 10 ]; then
        echo -e "      ${YELLOW}... and $((FLAKE8_COUNT - 10)) more${NC}"
    fi
    FAILED=1
fi

# Step 3: Mypy (type checking)
echo -e "${BOLD}[3/3]${NC} Mypy type checking..."
MYPY_OUTPUT=$($PYTHON_CMD -m mypy src/ 2>&1 || true)
if echo "$MYPY_OUTPUT" | grep -q "Success: no issues found"; then
    echo -e "      ${GREEN}✓${NC} No type errors"
else
    MYPY_ERRORS=$(echo "$MYPY_OUTPUT" | grep -c "error:" || echo "0")
    if [ "$MYPY_ERRORS" -gt 0 ]; then
        echo -e "      ${RED}✗${NC} Type errors found ($MYPY_ERRORS errors)"
        echo "$MYPY_OUTPUT" | grep "error:" | head -5
        if [ "$MYPY_ERRORS" -gt 5 ]; then
            echo -e "      ${YELLOW}... and $((MYPY_ERRORS - 5)) more${NC}"
        fi
        FAILED=1
    else
        echo -e "      ${GREEN}✓${NC} No type errors"
    fi
fi

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}  ✅ Quick checks passed (${DURATION}s)${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}  Note: Full tests run on push (pre-push hook)${NC}"
    exit 0
else
    echo -e "${RED}  ❌ Quick checks FAILED (${DURATION}s)${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "\n${YELLOW}Fix issues before committing. Common fixes:${NC}"
    echo -e "  ${BLUE}black .${NC}              # Fix formatting"
    echo -e "  ${BLUE}# Fix linting issues manually${NC}"
    echo -e "  ${BLUE}# Add type hints for mypy${NC}"
    exit 1
fi
