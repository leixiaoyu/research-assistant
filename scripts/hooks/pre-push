#!/bin/bash
#
# Pre-push hook - FULL verification before pushing to remote
#
# This hook runs the complete verification suite including tests.
# It ensures all quality gates pass before code reaches the remote.
#
# What runs here:
#   - Black formatting check
#   - Flake8 linting
#   - Mypy type checking
#   - Pragma audit
#   - Full pytest with ≥99% coverage
#
# To bypass (emergencies only): git push --no-verify
#
# Installation: ./scripts/setup_hooks.sh

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Get repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Read push info
while read local_ref local_sha remote_ref remote_sha; do
    # Skip if deleting a branch
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # Get branch name
    BRANCH=$(echo "$remote_ref" | sed 's/refs\/heads\///')

    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  Pre-push: Full Verification${NC}"
    echo -e "${BLUE}  Pushing to: ${BOLD}$BRANCH${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    # Check if verify.sh exists
    if [ ! -f "./verify.sh" ]; then
        echo -e "${RED}ERROR: verify.sh not found${NC}"
        exit 1
    fi

    # Make it executable if needed
    [ ! -x "./verify.sh" ] && chmod +x ./verify.sh

    START_TIME=$(date +%s)

    echo -e "\n${YELLOW}Running full verification suite...${NC}"
    echo -e "${YELLOW}This includes: formatting, linting, types, and full test suite${NC}\n"

    if ./verify.sh; then
        END_TIME=$(date +%s)
        DURATION=$((END_TIME - START_TIME))

        echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${GREEN}  ✅ All checks passed! (${DURATION}s)${NC}"
        echo -e "${GREEN}  Proceeding with push to ${BRANCH}...${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        exit 0
    else
        END_TIME=$(date +%s)
        DURATION=$((END_TIME - START_TIME))

        echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}  ❌ Verification FAILED! (${DURATION}s)${NC}"
        echo -e "${RED}  Push to ${BRANCH} blocked.${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "\n${YELLOW}Fix the issues above before pushing.${NC}"
        echo -e "${YELLOW}To run verification manually: ${BLUE}./verify.sh${NC}"
        exit 1
    fi
done

exit 0
